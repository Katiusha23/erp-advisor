# ============================================================
# ERP Advisor Backend — Variabile de mediu
# Copiați acest fișier în .env și completați valorile reale
# ============================================================

# Calea către baza de date SQLite (locală)
DATABASE_URL=./db/erp_advisor.db

# URL-ul frontend-ului pentru CORS (înlocuiți cu domeniul Vercel după deploy)
FRONTEND_URL=http://localhost:5173

# Portul pe care rulează serverul
PORT=3001

# Mediul de execuție (development / production)
NODE_ENV=development
